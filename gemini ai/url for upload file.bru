meta {
  name: url for upload file 
  type: http
  seq: 2
}

post {
  url: https://generativelanguage.googleapis.com/upload/v1beta/files?key=AIzaSyDM1KL99YLPdNdWmIyM50PZzUO0KqOZdp4
  body: json
  auth: inherit
}

params:query {
  key: AIzaSyDM1KL99YLPdNdWmIyM50PZzUO0KqOZdp4
}

headers {
  Content-Type: application/json
  X-Goog-Upload-Protocol: resumable
  X-Goog-Upload-Command: start
  X-Goog-Upload-Header-Content-Length: {{NUM_BYTES}}
  X-Goog-Upload-Header-Content-Type: text/plain
}

body:json {
  {
      "file" : {
          "display_name" : "plan.txt"
      }
  }
}

script:pre-request {
  const fs = require('fs');
  
  // Set the path to your file
  const filePath = "C:\Users\HP\Downloads\plan.txt"; // Replace with your file path
  
  // Calculate file size
  const stats = fs.statSync(filePath);
  const numBytes = stats.size;
  
  // Store NUM_BYTES as an environment variable
  bru.setEnvVar("NUM_BYTES", numBytes);
  
  console.log(`NUM_BYTES: ${numBytes}`);
  
}

settings {
  encodeUrl: true
}
